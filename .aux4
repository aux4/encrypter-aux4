{
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "build",
          "execute": [
            "aux4 builder all"
          ],
          "help": {
            "text": "Build the package for all platforms"
          }
        },
        {
          "name": "build-local",
          "execute": [
            "go build -o ${packageDir}/package/aux4-encrypter ${packageDir}"
          ],
          "help": {
            "text": "Build the binary for the local platform (for testing)"
          }
        },
        {
          "name": "install",
          "execute": [
            "aux4 aux4 releaser install --dir package --noBuild true"
          ],
          "help": {
            "text": "Install the package locally"
          }
        },
        {
          "name": "test",
          "execute": [
            "aux4 test run --dir package/test"
          ],
          "help": {
            "text": "Run tests"
          }
        },
        {
          "name": "builder",
          "execute": [
            "profile:builder"
          ],
          "help": {
            "text": "Build the package"
          }
        }
      ]
    },
    {
      "name": "builder",
      "commands": [
        {
          "name": "darwin",
          "execute": [
            "GOOS=darwin GOARCH=amd64 go build -o ${packageDir}/package/dist/darwin/amd64/aux4-encrypter ${packageDir}",
            "GOOS=darwin GOARCH=arm64 go build -o ${packageDir}/package/dist/darwin/arm64/aux4-encrypter ${packageDir}"
          ],
          "help": {
            "text": "Build the app for darwin"
          }
        },
        {
          "name": "linux",
          "execute": [
            "GOOS=linux GOARCH=amd64 go build -o ${packageDir}/package/dist/linux/amd64/aux4-encrypter ${packageDir}",
            "GOOS=linux GOARCH=arm64 go build -o ${packageDir}/package/dist/linux/arm64/aux4-encrypter ${packageDir}",
            "GOOS=linux GOARCH=386 go build -o ${packageDir}/package/dist/linux/386/aux4-encrypter ${packageDir}"
          ],
          "help": {
            "text": "Build the app for linux"
          }
        },
        {
          "name": "windows",
          "execute": [
            "GOOS=windows GOARCH=amd64 go build -o ${packageDir}/package/dist/windows/amd64/aux4-encrypter.exe ${packageDir}",
            "GOOS=windows GOARCH=arm64 go build -o ${packageDir}/package/dist/windows/arm64/aux4-encrypter.exe ${packageDir}",
            "GOOS=windows GOARCH=386 go build -o ${packageDir}/package/dist/windows/386/aux4-encrypter.exe ${packageDir}"
          ],
          "help": {
            "text": "Build the app for windows"
          }
        },
        {
          "name": "all",
          "execute": [
            "aux4 builder darwin",
            "aux4 builder linux",
            "aux4 builder windows"
          ],
          "help": {
            "text": "Build the app for all platforms"
          }
        }
      ]
    }
  ]
}
