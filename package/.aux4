{
  "scope": "aux4",
  "name": "encrypter-aux4",
  "version": "0.0.0",
  "description": "Local AES-256-GCM encryption provider for the aux4/encrypter facade",
  "license": "Apache-2.0",
  "tags": [
    "aux4",
    "encrypter",
    "encryption",
    "aes",
    "gcm",
    "crypto"
  ],
  "dependencies": [
    "aux4/encrypter"
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "encrypter",
          "execute": [
            "profile:encrypter"
          ],
          "help": {
            "text": "Encryption facade"
          }
        }
      ]
    },
    {
      "name": "encrypter",
      "commands": [
        {
          "name": "provider",
          "execute": [
            "profile:encrypter:provider"
          ],
          "help": {
            "text": "Encryption providers"
          }
        }
      ]
    },
    {
      "name": "encrypter:provider",
      "commands": [
        {
          "name": "aux4",
          "execute": [
            "profile:encrypter:provider:aux4"
          ],
          "help": {
            "text": "Local AES-256-GCM encrypter"
          }
        }
      ]
    },
    {
      "name": "encrypter:provider:aux4",
      "commands": [
        {
          "name": "encrypt",
          "execute": [
            "alias:${packageDir}/aux4-encrypter encrypt values(secret,text)"
          ],
          "help": {
            "text": "Encrypt plaintext with AES-256-GCM",
            "variables": [
              {
                "name": "secret",
                "text": "AES key material (any length; hashed to 256 bits)",
                "env": "AUX4_SECRET"
              },
              {
                "name": "text",
                "text": "The plaintext to encrypt (positional arg or stdin)",
                "default": "",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "decrypt",
          "execute": [
            "alias:${packageDir}/aux4-encrypter decrypt values(secret,text)"
          ],
          "help": {
            "text": "Decrypt base64 ciphertext with AES-256-GCM",
            "variables": [
              {
                "name": "secret",
                "text": "AES key material (any length; hashed to 256 bits)",
                "env": "AUX4_SECRET"
              },
              {
                "name": "text",
                "text": "The base64 ciphertext to decrypt (positional arg or stdin)",
                "default": "",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "generate-secret",
          "execute": [
            "${packageDir}/aux4-encrypter generate-secret value(length)"
          ],
          "help": {
            "text": "Generate a random secret",
            "variables": [
              {
                "name": "length",
                "text": "The length of the secret",
                "default": "32",
                "arg": true
              }
            ]
          }
        }
      ]
    }
  ]
}
